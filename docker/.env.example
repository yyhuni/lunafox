# LunaFox installer generates `docker/.env` automatically.
# This file is comments-only and acts as a full variable reference for
# manual recovery/debug scenarios.
# In production, release version/image variables should come from
# `release.manifest.yaml` as the single source of truth.

# ============================================================
# Installer-managed image/runtime variables
# ============================================================
# IMAGE_TAG=dev
# RELEASE_VERSION=dev
# AGENT_VERSION=dev
# WORKER_VERSION=dev
# IMAGE_REGISTRY=docker.io
# IMAGE_NAMESPACE=yyhuni
# AGENT_IMAGE_REF=docker.io/yyhuni/lunafox-agent@sha256:<digest>
# WORKER_IMAGE_REF=docker.io/yyhuni/lunafox-worker@sha256:<digest>
# LUNAFOX_SHARED_DATA_VOLUME_BIND=lunafox_data:/opt/lunafox
# PUBLIC_URL=https://your-domain.com:18443
# PUBLIC_PORT=18443
# GO111MODULE=on
# GOPROXY=https://proxy.golang.org,direct

# ============================================================
# Security
# ============================================================
# JWT_SECRET=change-me-in-production-use-a-long-random-string
# WORKER_TOKEN=change-me-worker-token
# JWT_ACCESS_EXPIRE=15m
# JWT_REFRESH_EXPIRE=168h

# ============================================================
# Server runtime
# ============================================================
# SERVER_PORT=8080
# GIN_MODE=release
# LOG_LEVEL=info
# LOG_FORMAT=json
# WORDLISTS_BASE_PATH=/opt/lunafox/wordlists
# LOKI_URL=http://loki:3100

# ============================================================
# PostgreSQL
# ============================================================
# DB_HOST=postgres
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=lunafox
# DB_SSLMODE=disable
# DB_TIMEZONE=UTC
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=300

# ============================================================
# Redis
# ============================================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ============================================================
# Dev-only frontend override
# ============================================================
# NEXT_PUBLIC_BACKEND_URL=
